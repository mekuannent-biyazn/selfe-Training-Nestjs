generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  APPLICANT
}

enum ApplicantStatus {
  PENDING
  SHORTLISTED
  ACCEPTED
  REJECTED
}

enum InternshipTrack {
  FRONTEND
  BACKEND
  MOBILE
  UI_UX
  DATA_ANALYTICS
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  fullName  String
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Applicant {
  id              String            @id @default(uuid()) @db.Uuid

  fullName        String
  email           String            @unique
  phone           String?

  university      String?
  department      String?
  graduationYear  Int?

  track           InternshipTrack
  status          ApplicantStatus  @default(PENDING)

  notes           String?          @db.VarChar(1000)

  deletedAt       DateTime?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@map("applicants")
}